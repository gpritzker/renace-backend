<div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
  <%= link_to admin_users_path, class: 'btn btn-sm btn-outline-secondary' do %>
    &larr; Usuarios
  <% end %>
  <h1 class="h4 mb-0"><%= [@user.first_name, @user.last_name].compact.join(' ').presence || @user.email %></h1>
  <span class="badge <%= @user.admin? ? 'bg-danger' : 'bg-secondary' %>">
    <%= @user.admin? ? 'Admin' : 'Usuario' %>
  </span>
  <span class="badge <%= @user.confirmed? ? 'bg-success' : 'bg-warning text-dark' %>">
    <%= @user.confirmed? ? 'Confirmado' : 'Sin confirmar' %>
  </span>
  <% if @user.premium? %>
    <span class="badge bg-warning text-dark">⭐ Premium</span>
  <% end %>
</div>

<div class="row g-4">
  <div class="col-lg-8">

    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold">Datos personales</div>
      <div class="card-body small">
        <div class="row g-2">
          <div class="col-6"><strong>ID:</strong> <%= @user.id %></div>
          <div class="col-6"><strong>Email:</strong> <%= @user.email %></div>
          <div class="col-6"><strong>Nombre:</strong> <%= @user.first_name || '—' %></div>
          <div class="col-6"><strong>Apellido:</strong> <%= @user.last_name || '—' %></div>
          <div class="col-6"><strong>DNI:</strong> <%= @user.dni || '—' %></div>
          <div class="col-6"><strong>Teléfono:</strong> <%= @user.phone || '—' %></div>
          <div class="col-6"><strong>Nacimiento:</strong> <%= @user.birth_date&.strftime('%d/%m/%Y') || '—' %></div>
          <div class="col-6"><strong>Registrado:</strong> <%= @user.created_at.strftime('%d/%m/%Y %H:%M') %></div>
          <div class="col-6">
            <strong>Aprobado:</strong>
            <%= @user.approved_at ? @user.approved_at.strftime('%d/%m/%Y %H:%M') : '—' %>
          </div>
          <div class="col-6"><strong>Cápsulas:</strong> <%= @user.capsules.count %></div>
        </div>
      </div>
    </div>

    <div class="card shadow-sm mb-3">
      <div class="card-header fw-semibold">Suscripción</div>
      <div class="card-body small">
        <div class="row g-2">
          <div class="col-6">
            <strong>Plan:</strong>
            <% if @user.premium? %>
              <span class="badge bg-warning text-dark ms-1">⭐ Premium</span>
            <% else %>
              <span class="badge bg-secondary ms-1">Gratis</span>
            <% end %>
          </div>
          <div class="col-6">
            <strong>ID suscripción MP:</strong>
            <%= @user.mp_subscription_id.presence || '—' %>
          </div>
        </div>
      </div>
    </div>

    <% if @user.capsules.any? %>
    <div class="card shadow-sm">
      <div class="card-header fw-semibold">Cápsulas (<%= @user.capsules.count %>)</div>
      <div class="list-group list-group-flush">
        <% @user.capsules.order(created_at: :desc).each do |capsule| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <span class="fw-medium"><%= capsule.title %></span>
              <span class="badge <%= capsule.approved? ? 'bg-success' : 'bg-warning text-dark' %> ms-2">
                <%= capsule.approved? ? 'Aprobada' : 'Pendiente' %>
              </span>
              <% if capsule.open_at %>
                <small class="text-muted ms-2">Abre: <%= capsule.open_at.strftime('%d/%m/%Y') %></small>
              <% end %>
            </div>
            <%= link_to 'Ver', admin_capsule_path(capsule), class: 'btn btn-sm btn-outline-primary' %>
          </div>
        <% end %>
      </div>
    </div>
    <% end %>

  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-header fw-semibold">Acciones</div>
      <div class="card-body d-grid gap-2">
        <%= link_to 'Editar datos', edit_admin_user_path(@user), class: 'btn btn-primary' %>

        <% unless @user.confirmed? %>
          <%= button_to 'Confirmar cuenta', confirm_admin_user_path(@user),
              method: :patch, class: 'btn btn-success' %>
        <% end %>

        <%= button_to @user.premium? ? '⭐ Quitar Premium' : '⭐ Dar Premium',
            toggle_premium_admin_user_path(@user),
            method: :patch,
            class: "btn #{@user.premium? ? 'btn-outline-warning' : 'btn-warning'}" %>

        <%= button_to 'Eliminar usuario', admin_user_path(@user),
            method: :delete,
            form: { data: { turbo_confirm: "¿Eliminás a #{@user.email}?" } },
            class: 'btn btn-outline-danger' %>
      </div>
    </div>
  </div>
</div>
