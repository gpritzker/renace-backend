<%= form_with(model: [:admin, @user], local: true) do |form| %>
  <% if @user.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :email, 'Email', class: 'form-label fw-semibold' %>
    <%= form.email_field :email, class: 'form-control' %>
  </div>

  <div class="mb-4">
    <div class="form-check form-switch">
      <%= form.check_box :admin, class: 'form-check-input', role: 'switch', id: 'adminSwitch' %>
      <%= form.label :admin, 'Es administrador', class: 'form-check-label', for: 'adminSwitch' %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit 'Guardar cambios', class: 'btn btn-primary px-4' %>
    <%= link_to 'Cancelar', admin_user_path(@user), class: 'btn btn-outline-secondary' %>
  </div>
<% end %>
