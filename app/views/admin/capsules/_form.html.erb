<%= form_with(model: [:admin, capsule], local: true) do |form| %>
  <% if capsule.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% capsule.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, 'Título', class: 'form-label fw-semibold' %>
    <%= form.text_field :title, class: 'form-control', placeholder: 'Título de la cápsula' %>
  </div>

  <div class="mb-3">
    <%= form.label :description, 'Descripción / Relato', class: 'form-label fw-semibold' %>
    <small class="text-muted d-block mb-1">Este texto será leído con la voz del usuario en ElevenLabs. Revisá redacción, puntuación y que fluya bien al oírlo.</small>
    <%= form.text_area :description, class: 'form-control font-monospace', rows: 18, placeholder: 'Escribí el relato...' %>
    <div class="form-text">
      <span id="char-count">0</span> caracteres
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :open_at, 'Fecha de apertura', class: 'form-label fw-semibold' %>
    <%= form.datetime_local_field :open_at, class: 'form-control', value: capsule.open_at&.strftime('%Y-%m-%dT%H:%M') %>
    <div class="form-text">Dejá vacío si querés que esté disponible de inmediato.</div>
  </div>

  <div class="mb-4">
    <div class="form-check form-switch">
      <%= form.check_box :approved, class: 'form-check-input', role: 'switch', id: 'approvedSwitch' %>
      <%= form.label :approved, 'Aprobada (visible al público)', class: 'form-check-label fw-semibold', for: 'approvedSwitch' %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit 'Guardar cambios', class: 'btn btn-primary px-4' %>
    <%= link_to 'Cancelar', admin_capsule_path(capsule), class: 'btn btn-outline-secondary' %>
  </div>
<% end %>

<script>
  const ta = document.querySelector('textarea');
  const counter = document.getElementById('char-count');
  if (ta && counter) {
    const update = () => counter.textContent = ta.value.length;
    update();
    ta.addEventListener('input', update);
  }
</script>
